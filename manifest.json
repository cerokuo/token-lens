{
  "manifest_version": 3,
  "name": "TokenLens",
  "version": "1.2.0",
  "description": "Real-time token usage, cost, and efficiency tracking for Claude, ChatGPT, and Gemini.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "options_page": "src/settings/settings.html",
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["src/injected/injected.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://claude.ai/*",
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "src/core/token-counter.js",
        "src/core/text-analyzer.js",
        "src/core/cost-calculator.js",
        "src/core/redundancy-detector.js",
        "src/core/storage.js",
        "src/core/api-client.js",
        "src/core/quota-tracker.js",
        "src/content/platform-detector.js",
        "src/content/dom-extractor.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "TokenLens"
  }
}
